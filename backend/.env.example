# ZhipuAI API key (Anthropic-compatible endpoint)
ZHIPU_API_KEY=your-api-key-here

# Anthropic-compatible base URL (ZhipuAI)
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Model name
AI_MODEL=glm-4-flash

# JWT secret (auto-generated if not set, but set explicitly for production)
JWT_SECRET=your-jwt-secret-here

# Server port
PORT=3001
